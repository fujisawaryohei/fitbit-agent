# バックエンドのURL
BACKEND_URL=http://localhost:8000

# FitbitのOAuthリダイレクトURI（バックエンドのコールバックURL）
# localhost使用時: http://localhost:8000/auth/fitbit/callback
# ngrok使用時: https://<ngrok-id>.ngrok-free.app/auth/fitbit/callback
FITBIT_REDIRECT_URI=http://localhost:8000/auth/fitbit/callback

# 許可するオリジン（ngrok等の外部URLをカンマ区切りで指定）
# localhost使用時は空でよい
# ngrok使用時: https://<ngrok-id>.ngrok-free.app
CORS_ORIGINS=
